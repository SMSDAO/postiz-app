# AI Poster Application - Environment Configuration Template

# ============================================================================
# DATABASE CONFIGURATION (Supabase or NEON)
# ============================================================================

# For Supabase:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
# SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
# SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# For NEON:
# DATABASE_URL="postgresql://[user]:[password]@[hostname]/[dbname]?sslmode=require"
# NEON_DATABASE_URL="postgresql://[user]:[password]@[hostname]/[dbname]?sslmode=require"

# Connection pooling (recommended for serverless)
DATABASE_URL="postgresql://postiz-user:postiz-password@localhost:5432/postiz-db-local"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=20000

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL="redis://localhost:6379"
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# ============================================================================
# APPLICATION URLS
# ============================================================================
FRONTEND_URL="http://localhost:4200"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"
BACKEND_INTERNAL_URL="http://localhost:3000"

# AI Poster Dashboard URLs
AI_POSTER_USER_DASHBOARD_URL="http://localhost:4300"
AI_POSTER_ADMIN_DASHBOARD_URL="http://localhost:4301"
AI_POSTER_DEV_DASHBOARD_URL="http://localhost:4302"

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET="random string for your JWT secret, make it long"
JWT_EXPIRATION="7d"
JWT_REFRESH_EXPIRATION="30d"

# Session configuration
SESSION_SECRET="another-random-string-for-sessions"
SESSION_MAX_AGE=604800000

# Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# AI POSTER SPECIFIC CONFIGURATION
# ============================================================================

# AI Service Configuration
OPENAI_API_KEY=""
AI_POSTER_MODEL="gpt-4"
AI_POSTER_MAX_TOKENS=2000
AI_POSTER_TEMPERATURE=0.7

# Auto-healing configuration
AUTO_HEAL_ENABLED=true
AUTO_HEAL_CHECK_INTERVAL=60000
AUTO_HEAL_RETRY_ATTEMPTS=3
AUTO_HEAL_RETRY_DELAY=5000

# Auto-configuration
AUTO_CONFIG_ENABLED=true
AUTO_CONFIG_CHECK_ON_STARTUP=true

# Automatic testing
AUTO_TEST_ENABLED=false
AUTO_TEST_ON_DEPLOY=true
AUTO_FIX_ENABLED=false

# Health monitoring
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# ============================================================================
# STORAGE & MEDIA
# ============================================================================
STORAGE_PROVIDER="local"
UPLOAD_DIRECTORY="./uploads"
NEXT_PUBLIC_UPLOAD_STATIC_DIRECTORY="/uploads"
MAX_FILE_SIZE=10485760

# Cloudflare R2 (optional)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ACCESS_KEY=""
CLOUDFLARE_SECRET_ACCESS_KEY=""
CLOUDFLARE_BUCKETNAME=""
CLOUDFLARE_BUCKET_URL=""
CLOUDFLARE_REGION="auto"

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================
RESEND_API_KEY=""
EMAIL_FROM_ADDRESS="noreply@ai-poster.app"
EMAIL_FROM_NAME="AI Poster"
DISABLE_REGISTRATION=false

# ============================================================================
# SOCIAL MEDIA INTEGRATIONS
# ============================================================================
X_API_KEY=""
X_API_SECRET=""
X_CLIENT=""
X_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
THREADS_APP_ID=""
THREADS_APP_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""
PINTEREST_CLIENT_ID=""
PINTEREST_CLIENT_SECRET=""
MASTODON_CLIENT_ID=""
MASTODON_CLIENT_SECRET=""

# ============================================================================
# PAYMENT PROCESSING
# ============================================================================
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_SIGNING_KEY=""
STRIPE_SIGNING_KEY_CONNECT=""
FEE_AMOUNT=0.05

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
LOG_LEVEL="info"
LOG_FORMAT="json"
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_TRACKING=true

# Sentry (optional)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
NODE_ENV="development"
NX_ADD_PLUGINS=false
IS_GENERAL="true"
NOT_SECURED=false

# Debug flags
DEBUG_MODE=false
VERBOSE_LOGGING=false

# ============================================================================
# VERCEL DEPLOYMENT
# ============================================================================
# These are automatically set by Vercel
# VERCEL="1"
# VERCEL_ENV="production"
# VERCEL_URL=""
# VERCEL_GIT_COMMIT_SHA=""
# VERCEL_GIT_COMMIT_REF=""

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_AI_POSTER_ENABLED=true
FEATURE_AUTO_HEALING_ENABLED=true
FEATURE_AUTO_CONFIG_ENABLED=true
FEATURE_ADMIN_DASHBOARD_ENABLED=true
FEATURE_DEV_DASHBOARD_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_WEBHOOKS_ENABLED=true
